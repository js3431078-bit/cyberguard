# Copy this file to .env and fill in your values
# NEVER commit the real .env to GitHub

SECRET_KEY=your_strong_random_secret_key_here

# Admin credentials
ADMIN_ID=admin
ADMIN_PASSWORD=YourStrongAdminPassword@2026

# PostgreSQL Database (Supabase / Railway / any Postgres)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# SMTP Email (Gmail App Password recommended)
SMTP_USER=youremail@gmail.com
SMTP_PASS=your_gmail_app_password

# OR use Resend API (easier, no port issues on cloud)
RESEND_KEY=re_your_resend_api_key

# AI APIs (optional)
GEMINI_API_KEY=your_gemini_key
GROQ_API_KEY=your_groq_key
